---
import { CALENDLY_URL, NAV_LINKS } from "../config";

const currentPath = Astro.url.pathname;
const normalize = (p: string) =>
  p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p;
// A link is "active" only when it's a non-anchor link and matches the current path,
// ignoring any trailing slash differences between Astro's pathname and our nav hrefs.
const isActive = (href: string) =>
  !href.includes("#") && normalize(href) === normalize(currentPath);
---
<header class="nav" id="nav">
  <div class="nav-inner">
    <a class="brand" href="/" aria-label="Lantern Strategic, home">
      <img src="/images/lantern-mark.png" alt="" />
      <span class="brand-word">Lantern <em>Strategic</em></span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <a
      href={CALENDLY_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta"
    >
      Book a call <span aria-hidden="true">→</span>
    </a>
    <button class="menu-btn" aria-label="Menu" aria-expanded="false" id="menuBtn">
      <svg width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
        <path d="M1 1H17M1 7H17M1 13H17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <div class="menu-sheet" id="menuSheet">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        aria-current={isActive(link.href) ? "page" : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-parchment) 88%, transparent);
    backdrop-filter: blur(10px) saturate(140%);
    -webkit-backdrop-filter: blur(10px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .nav[data-scrolled="true"] {
    border-color: var(--color-stone);
  }
  .nav-inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding-inline: var(--gutter);
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--color-charcoal);
  }
  .brand img {
    height: 40px;
    width: auto;
    display: block;
  }
  .brand-word {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 500;
    color: var(--color-crimson);
    letter-spacing: 0.005em;
  }
  .brand-word em {
    font-style: normal;
    color: var(--color-charcoal);
    font-weight: 400;
  }
  .nav-links {
    display: none;
    align-items: center;
    gap: 30px;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--color-charcoal);
    font-size: 15px;
    font-weight: 500;
    position: relative;
    padding: 6px 0;
  }
  .nav-links a:hover {
    color: var(--color-crimson);
  }
  .nav-links a[aria-current="page"] {
    color: var(--color-crimson);
    border-bottom: 2px solid var(--color-crimson);
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-crimson);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 999px;
    transition: background 0.15s ease, transform 0.15s ease;
    letter-spacing: 0.005em;
  }
  .nav-cta:hover {
    background: var(--color-deep-crimson);
  }
  @media (min-width: 880px) {
    .nav-links {
      display: inline-flex;
    }
  }

  /* Mobile menu button */
  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-stone);
    background: transparent;
    border-radius: 10px;
    color: var(--color-charcoal);
    cursor: pointer;
  }
  @media (min-width: 880px) {
    .menu-btn {
      display: none;
    }
  }

  .menu-sheet {
    display: none;
    border-top: 1px solid var(--color-stone);
    background: var(--color-parchment);
    padding: 12px var(--gutter) 18px;
  }
  .menu-sheet a {
    display: block;
    padding: 14px 4px;
    text-decoration: none;
    color: var(--color-charcoal);
    font-size: 18px;
    font-weight: 500;
    border-bottom: 1px solid var(--color-stone);
  }
  .menu-sheet a:last-of-type {
    border-bottom: none;
  }
  .menu-sheet a[aria-current="page"] {
    color: var(--color-crimson);
  }
  .menu-sheet[data-open="true"] {
    display: block;
  }
</style>

<script>
  // Nav scroll state
  const nav = document.getElementById("nav") as HTMLElement | null;
  if (nav) {
    const onScroll = () =>
      nav.setAttribute("data-scrolled", window.scrollY > 8 ? "true" : "false");
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu
  const mb = document.getElementById("menuBtn") as HTMLButtonElement | null;
  const ms = document.getElementById("menuSheet") as HTMLElement | null;
  if (mb && ms) {
    mb.addEventListener("click", () => {
      const open = ms.getAttribute("data-open") === "true";
      ms.setAttribute("data-open", open ? "false" : "true");
      mb.setAttribute("aria-expanded", open ? "false" : "true");
    });
    ms.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        ms.setAttribute("data-open", "false");
        mb.setAttribute("aria-expanded", "false");
      })
    );
  }
</script>
