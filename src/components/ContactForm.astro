---
const ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
---
<div class="contact-form-wrap">
  <div class="form-success" id="formSuccess" data-show="false" role="status" aria-live="polite">
    Thanks &mdash; your message is on its way. I'll be in touch within a business day.
  </div>

  <form class="contact-form" id="contactForm" novalidate>
    <input type="hidden" name="access_key" value={ACCESS_KEY} />
    <input type="hidden" name="from_name" value="Lantern Strategic Website" />
    <input type="hidden" name="subject" value="New contact from lanternstrategic.com" />

    {/* Honeypot — visually hidden but not display:none */}
    <input
      type="text"
      name="botcheck"
      class="botcheck"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />

    <div class="form-error" id="formError" data-show="false" role="alert">
      Something went wrong sending your message. Please try again, or email
      <a href="mailto:zach@lanternstrategic.com">zach@lanternstrategic.com</a> directly.
    </div>

    <div class="form-row two">
      <div class="field">
        <label for="f-name">Name</label>
        <input id="f-name" name="name" type="text" required autocomplete="name" />
      </div>
      <div class="field">
        <label for="f-company">Company</label>
        <input id="f-company" name="company" type="text" required autocomplete="organization" />
      </div>
    </div>
    <div class="form-row two">
      <div class="field">
        <label for="f-email">Email</label>
        <input id="f-email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for="f-phone">Phone <span class="opt">(optional)</span></label>
        <input id="f-phone" name="phone" type="tel" autocomplete="tel" />
      </div>
    </div>
    <div class="field">
      <label for="f-mind">What's on your mind?</label>
      <textarea
        id="f-mind"
        name="message"
        placeholder="A sentence or two on what you're working through is plenty."
      ></textarea>
    </div>
    <div class="form-foot">
      <p class="privacy">
        Your note goes straight to Zach. It isn't added to a list and won't be used for
        follow-up sales emails.
      </p>
      <button class="btn btn-primary btn-arrow" type="submit" id="formSubmit">Send</button>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const success = document.getElementById("formSuccess") as HTMLElement | null;
  const errorBox = document.getElementById("formError") as HTMLElement | null;
  const submitBtn = document.getElementById("formSubmit") as HTMLButtonElement | null;

  if (form && success && errorBox && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Hide any previous error
      errorBox.setAttribute("data-show", "false");

      // Native validation for required fields
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const formData = new FormData(form);

      // If the honeypot is filled, silently "succeed" without sending
      const botcheck = formData.get("botcheck");
      if (typeof botcheck === "string" && botcheck.trim().length > 0) {
        form.style.display = "none";
        success.setAttribute("data-show", "true");
        return;
      }

      const payload: Record<string, string> = {};
      formData.forEach((value, key) => {
        if (typeof value === "string") payload[key] = value;
      });

      submitBtn.disabled = true;
      const originalLabel = submitBtn.textContent;
      submitBtn.textContent = "Sending…";

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(payload),
        });

        const result = await res.json().catch(() => ({}));

        if (res.ok && result && result.success) {
          form.style.display = "none";
          success.setAttribute("data-show", "true");
        } else {
          errorBox.setAttribute("data-show", "true");
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      } catch {
        errorBox.setAttribute("data-show", "true");
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    });
  }
</script>

<style>
  .contact-form-wrap {
    display: grid;
    gap: 18px;
  }

  form.contact-form {
    background: color-mix(in oklab, var(--color-parchment) 96%, var(--color-charcoal));
    color: var(--color-charcoal);
    border-radius: 8px;
    padding: clamp(28px, 3vw, 40px);
    display: grid;
    gap: 18px;
  }

  /* Honeypot — visually hidden but NOT display:none */
  .botcheck {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 600px) {
    .form-row.two { grid-template-columns: 1fr 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .field label {
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-warm-gray);
  }
  .field label .opt {
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--color-warm-gray);
    margin-left: 6px;
    opacity: 0.8;
  }
  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-charcoal);
    background: var(--color-parchment);
    border: 1px solid var(--color-stone);
    border-radius: 6px;
    padding: 13px 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
  }
  .field textarea {
    resize: vertical;
    min-height: 130px;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-crimson);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-crimson) 18%, transparent);
  }

  .form-foot {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
  }
  .form-foot .privacy {
    font-size: 13px;
    color: var(--color-warm-gray);
    max-width: 32ch;
    margin: 0;
  }

  .form-success {
    background: var(--color-warm-blush);
    color: var(--color-crimson);
    padding: 14px 18px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    border: 1px solid color-mix(in oklab, var(--color-crimson) 20%, transparent);
    display: none;
  }
  .form-success[data-show="true"] { display: block; }

  .form-error {
    background: color-mix(in oklab, var(--color-rust) 14%, var(--color-parchment));
    color: var(--color-deep-crimson);
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 14.5px;
    line-height: 1.5;
    border: 1px solid color-mix(in oklab, var(--color-rust) 30%, transparent);
    display: none;
  }
  .form-error[data-show="true"] { display: block; }
  .form-error a {
    color: var(--color-crimson);
    text-decoration: underline;
  }

  /* Local button styles so the form is self-contained */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 16px;
    padding: 14px 26px;
    border-radius: 999px;
    transition: background 0.15s, color 0.15s, transform 0.15s, border-color 0.15s;
    cursor: pointer;
    border: 1px solid transparent;
    letter-spacing: 0.005em;
  }
  .btn-primary {
    background: var(--color-crimson);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--color-deep-crimson);
  }
  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .btn-arrow::after {
    content: "→";
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .btn-arrow:hover::after {
    transform: translateX(3px);
  }
</style>
