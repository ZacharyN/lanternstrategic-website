---
import Eyebrow from "./Eyebrow.astro";
import ContactForm from "./ContactForm.astro";
import {
  CALENDLY_URL,
  CALENDLY_LABEL,
  CONTACT_EMAIL,
  WEBSITE_URL,
  WEBSITE_LABEL,
} from "../config";
---
<section class="block dark" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-intro">
        <Eyebrow variant="dark">Let's talk</Eyebrow>
        <h2>The best first conversation is a short one.</h2>
        <p>
          Tell us a little about what you're working through, and we'll set up a call
          to see if there's a fit. No long forms, no sales pitch.
        </p>
        <div class="contact-channels">
          <a
            class="contact-channel"
            href={CALENDLY_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="label">Book directly</span>
            <span class="val">{CALENDLY_LABEL} →</span>
          </a>
          <a class="contact-channel" href={`mailto:${CONTACT_EMAIL}`}>
            <span class="label">Email</span>
            <span class="val">{CONTACT_EMAIL}</span>
          </a>
          <a
            class="contact-channel"
            href={WEBSITE_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="label">On the web</span>
            <span class="val">{WEBSITE_LABEL}</span>
          </a>
        </div>
      </div>

      <ContactForm />
    </div>
  </div>
</section>

<style>
  section.block {
    padding-top: clamp(72px, 9vw, 130px);
    padding-bottom: clamp(72px, 9vw, 130px);
    position: relative;
    z-index: 2;
  }
  .block.dark {
    background: var(--color-charcoal);
    color: var(--color-parchment);
  }

  .container {
    max-width: var(--max-content);
    margin: 0 auto;
    padding-inline: var(--gutter);
    position: relative;
    z-index: 2;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
  }
  @media (min-width: 880px) {
    .contact-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
    }
  }

  .contact-intro h2 {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-parchment);
    letter-spacing: -0.018em;
    font-size: clamp(30px, 4.2vw, 52px);
    line-height: 1.08;
    margin: 18px 0 0;
    text-wrap: balance;
    max-width: 14ch;
  }
  .contact-intro p {
    margin: 18px 0 0;
    color: color-mix(in oklab, var(--color-parchment) 78%, transparent);
    font-size: 17px;
    line-height: 1.6;
    max-width: 42ch;
  }

  .contact-channels {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .contact-channel {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(232, 224, 220, 0.15);
    text-decoration: none;
    color: var(--color-parchment);
    transition: color 0.15s;
  }
  .contact-channel:last-of-type {
    border-bottom: none;
  }
  .contact-channel:hover {
    color: var(--color-rust);
  }
  .contact-channel .label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in oklab, var(--color-parchment) 60%, transparent);
    width: 110px;
    flex: none;
  }
  .contact-channel .val {
    font-size: 16px;
    font-weight: 500;
  }
</style>
