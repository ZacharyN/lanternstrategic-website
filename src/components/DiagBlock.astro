---
import type { Diagnostic } from "../data/diagnostics";
import Button from "./Button.astro";

interface Props {
  diagnostic: Diagnostic;
}

const { diagnostic } = Astro.props;
---
<article class="diag" id={diagnostic.id}>
  <div class="diag-left">
    <div class="num">{diagnostic.num}</div>
    <h2>{diagnostic.title}</h2>
    <div class="meta">
      <div class="m-row">
        <span class="m-k">Time</span>
        <span class="m-v">{diagnostic.time}</span>
      </div>
      <div class="m-row">
        <span class="m-k">Best for</span>
        <span class="m-v">{diagnostic.bestFor}</span>
      </div>
    </div>
  </div>
  <div class="diag-body">
    <p class="diag-question">
      <span class="q-tag">The question it asks</span>
      <span set:html={diagnostic.question} />
    </p>
    {diagnostic.paragraphs.map((p) => (
      <p>{p}</p>
    ))}
    <div class="diag-domains">
      {diagnostic.domains.map((domain) => (
        <span class="domain" set:html={domain} />
      ))}
    </div>
    <div class="diag-actions">
      <Button href={diagnostic.downloadHref} download arrow>
        Download the diagnostic
      </Button>
      <span class="secondary">PDF · fillable · 15 minutes</span>
    </div>
  </div>
</article>

<style>
  .diag {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(24px, 3vw, 40px);
    align-items: start;
  }
  @media (min-width: 880px) {
    .diag {
      grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
      gap: 64px;
    }
  }
  /* Spacing between consecutive diag blocks is handled by the parent
     wrapper using the :global selector below — components can't target
     sibling instances of themselves with scoped styles alone. */
  :global(.diag + .diag) {
    margin-top: clamp(64px, 7vw, 96px);
    padding-top: clamp(64px, 7vw, 96px);
    border-top: 1px solid var(--color-stone);
  }

  .diag-left .num {
    font-family: var(--font-display);
    color: var(--color-crimson);
    font-size: clamp(56px, 6vw, 96px);
    line-height: 1;
    font-feature-settings: "lnum";
    margin-bottom: 14px;
  }
  .diag-left h2 {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-charcoal);
    letter-spacing: -0.016em;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.1;
    margin: 0;
    text-wrap: balance;
    max-width: 14ch;
  }
  .diag-left .meta {
    margin-top: 22px;
    display: grid;
    gap: 14px;
    padding: 18px 20px;
    background: var(--color-parchment);
    border: 1px solid var(--color-stone);
    border-radius: 6px;
    position: relative;
  }
  .diag-left .meta::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 3px;
    background: var(--color-crimson);
    border-radius: 0 2px 2px 0;
  }
  .diag-left .m-row {
    display: grid;
    gap: 4px;
  }
  .diag-left .m-k {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-warm-gray);
  }
  .diag-left .m-v {
    font-size: 14.5px;
    color: var(--color-charcoal);
    line-height: 1.45;
  }

  .diag-body {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .diag-question {
    margin-top: 4px;
    font-family: var(--font-display);
    font-size: clamp(22px, 2.2vw, 30px);
    line-height: 1.3;
    color: var(--color-charcoal);
    text-wrap: balance;
  }
  .diag-question .q-tag {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-bottom: 10px;
  }
  .diag-question :global(em) {
    font-style: italic;
    color: var(--color-crimson);
    font-weight: 500;
  }
  .diag-body > p:not(.diag-question) {
    color: color-mix(in oklab, var(--color-charcoal) 88%, transparent);
    font-size: 17px;
    line-height: 1.65;
    text-wrap: pretty;
    max-width: 62ch;
    margin: 0;
  }
  .diag-domains {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .diag-domains .domain {
    font-size: 12.5px;
    font-weight: 600;
    padding: 6px 12px;
    background: var(--color-warm-blush);
    color: var(--color-crimson);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .diag-actions {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }
  .diag-actions .secondary {
    font-size: 14.5px;
    color: var(--color-warm-gray);
  }
</style>
